{
  "name": "vps-launchpad",
  "version": "1.0.0",
  "description": "VPS Launchpad setup and config generation",
  "main": "index.js",
  "dependencies": {
    "express": "^4.22.1",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  },
  "scripts": {
    "start": "node server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "jest": {
    "rootDir": "..",
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "testEnvironment": "node",
    "modulePaths": [
      "<rootDir>/launchpad/node_modules"
    ]
  }
}
